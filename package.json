{
  "name": "project-sentinel",
  "version": "1.0.0",
  "description": "A CLI tool for monitoring real-time system performance metrics (CPU and memory utilization)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sentinel": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "system-monitor",
    "cli",
    "cpu",
    "memory",
    "performance",
    "devops"
  ],
  "author": "Project Sentinel Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "systeminformation": "^5.22.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.10.0",
    "@types/commander": "^2.10.0",
    "@types/mustache": "^4.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "prettier": "^3.2.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0"
  }
}
